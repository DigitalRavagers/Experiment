{
  "version": "1.0",
  "description": "AGI OS intent router — maps task intent to skill pipeline and agent persona",
  "intents": {
    "DESIGN_CREATE": {
      "triggers": ["design", "UI", "interface", "layout", "component", "landing page", "dashboard", "frontend", "webpage"],
      "pipeline": ["ui-ux-pro-max", "design-taste-frontend", "impeccable"],
      "agent": "design-agent",
      "ring": "functional"
    },
    "DESIGN_EXTRACT": {
      "triggers": ["extract design", "get tokens", "design language", "design system from", "what fonts", "what colors", "what typography"],
      "pipeline": ["extract-design"],
      "agent": "design-agent",
      "ring": "functional"
    },
    "DESIGN_BRAND": {
      "triggers": ["brand kit", "brand identity", "brand system", "style guide", "brand guidelines"],
      "pipeline": ["ckm-brand", "ckm-design-system", "brandkit"],
      "agent": "design-agent",
      "ring": "brand"
    },
    "VIDEO_CREATE": {
      "triggers": ["make video", "render video", "explainer", "social clip", "slideshow", "video content", "short form video"],
      "pipeline": ["hyperframes", "hyperframes-core"],
      "agent": "content-agent",
      "ring": "functional"
    },
    "VIDEO_ANIMATE": {
      "triggers": ["animate", "motion", "transition", "kinetic text", "animated", "motion graphics"],
